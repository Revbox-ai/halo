<%- include('partials/head', { title, settings }) %>
<% const currentPage = 'blog'; %>
<%- include('partials/nav') %>

<!-- HERO -->
<section style="background:var(--black); padding:140px 60px 80px; position:relative; overflow:hidden;">
  <div style="position:absolute; inset:0; background-image: linear-gradient(rgba(230,51,41,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(230,51,41,0.04) 1px, transparent 1px); background-size:60px 60px;"></div>
  <div class="section-inner" style="position:relative; z-index:1;">
    <div class="hero-label">Blog</div>
    <h1 style="font-family:var(--font-display); font-size:clamp(64px,7vw,100px); color:white; line-height:0.92; margin-bottom:20px;">
      Wiedza<br>o <em style="color:var(--red); font-style:normal;">marketingu</em><br>cyfrowym
    </h1>
    <p style="font-size:16px; color:rgba(255,255,255,0.5); max-width:550px; line-height:1.7;">
      Praktyczne porady, case studies i trendy dla firm lokalnych. Bez żargonu — po polsku i do rzeczy.
    </p>
  </div>
</section>

<!-- BLOG POSTS -->
<section style="background:white; padding:80px 60px;">
  <div class="section-inner">
    <% if (posts.length === 0) { %>
      <div style="text-align:center; padding:80px 0; color:var(--gray);">
        <div style="font-size:48px; margin-bottom:16px;">✍️</div>
        <p style="font-size:18px;">Brak wpisów na blogu.</p>
      </div>
    <% } else { %>
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(360px,1fr)); gap:28px;">
        <% for (const post of posts) { %>
          <article class="fade-in">
            <a href="/blog/<%= post.slug %>" style="text-decoration:none; display:block; height:100%;">
              <div style="background:var(--gray-light); height:180px; display:flex; align-items:center; justify-content:center; border-top:3px solid transparent; transition:border-color .25s;" onmouseover="this.style.borderColor='var(--red)'" onmouseout="this.style.borderColor='transparent'">
                <div style="font-size:56px;">📝</div>
              </div>
              <div style="padding:28px 0;">
                <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:10px;">
                  <%= new Date(post.created_at).toLocaleDateString('pl-PL', { year:'numeric', month:'long', day:'numeric' }) %>
                </div>
                <h2 style="font-size:20px; font-weight:700; color:var(--black); line-height:1.3; margin-bottom:12px; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--black)'">
                  <%= post.title %>
                </h2>
                <% if (post.excerpt) { %>
                  <p style="font-size:14px; line-height:1.7; color:var(--gray); margin-bottom:20px;"><%= post.excerpt %></p>
                <% } %>
                <span style="font-size:13px; color:var(--red); font-weight:600; letter-spacing:0.5px; display:flex; align-items:center; gap:6px;">
                  Czytaj dalej <span>→</span>
                </span>
              </div>
            </a>
          </article>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-inner">
    <div class="section-label">Porozmawiajmy</div>
    <h2 class="cta-title">Opowiedz mi o swoich<br><em>wyzwaniach</em></h2>
    <p class="cta-sub">Razem znajdziemy rozwiązanie. Bezpłatna konsultacja, bez zobowiązań.</p>
    <div class="cta-btns">
      <a href="/kontakt" class="btn-primary">Umów konsultację</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
<script src="/js/extra.js"></script>
</body>
</html>
