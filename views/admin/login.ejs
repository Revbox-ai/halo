<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-login-page">
  <div class="login-wrap">
    <div class="login-logo">
      <img src="/images/halo_logo_black.png" alt="Halo" style="height:48px;">
    </div>
    <h1 class="login-title">Panel administracyjny</h1>
    <% if (flash && flash.error) { %>
      <div class="alert alert-error"><%= flash.error %></div>
    <% } %>
    <form action="/admin/login" method="POST" class="login-form">
      <div class="form-group">
        <label>Login</label>
        <input type="text" name="username" required autofocus>
      </div>
      <div class="form-group">
        <label>Hasło</label>
        <input type="password" name="password" required>
      </div>
      <button type="submit" class="btn btn-red btn-block">Zaloguj się</button>
    </form>
    <p style="text-align:center; margin-top:24px; font-size:13px; color:#999;">
      <a href="/" style="color:#999;">← Wróć do strony</a>
    </p>
  </div>
</body>
</html>
