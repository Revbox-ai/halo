<%- include('partials/head', { title, settings, metaDescription: post.meta_description }) %>
<% const currentPage = 'blog'; %>
<%- include('partials/nav') %>

<!-- HERO -->
<section style="background:var(--black); padding:140px 60px 80px; position:relative; overflow:hidden;">
  <div style="position:absolute; inset:0; background-image: linear-gradient(rgba(230,51,41,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(230,51,41,0.04) 1px, transparent 1px); background-size:60px 60px;"></div>
  <div class="section-inner" style="max-width:800px; position:relative; z-index:1;">
    <div style="margin-bottom:24px;">
      <a href="/blog" style="font-size:13px; color:rgba(255,255,255,0.4); text-decoration:none; letter-spacing:1px; text-transform:uppercase; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">← Powrót do bloga</a>
    </div>
    <div style="font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:16px;">
      <%= new Date(post.created_at).toLocaleDateString('pl-PL', { year:'numeric', month:'long', day:'numeric' }) %>
    </div>
    <h1 style="font-family:var(--font-display); font-size:clamp(40px,5vw,68px); color:white; line-height:1.05; margin-bottom:20px;">
      <%= post.title %>
    </h1>
    <% if (post.excerpt) { %>
      <p style="font-size:17px; line-height:1.7; color:rgba(255,255,255,0.5); max-width:600px;"><%= post.excerpt %></p>
    <% } %>
  </div>
</section>

<!-- CONTENT -->
<section style="background:white; padding:80px 60px;">
  <div style="max-width:760px; margin:0 auto;">
    <div class="blog-content fade-in">
      <%- post.content %>
    </div>

    <!-- Share -->
    <div style="margin-top:60px; padding-top:40px; border-top:1px solid #eee; display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
      <span style="font-size:13px; color:var(--gray); letter-spacing:1px; text-transform:uppercase;">Udostępnij:</span>
      <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('https://halo.pl/blog/' + post.slug) %>" target="_blank" rel="noopener" style="padding:10px 20px; background:var(--gray-light); font-size:13px; font-weight:600; text-decoration:none; color:var(--text); transition:background .2s;" onmouseover="this.style.background='var(--red)'; this.style.color='white'" onmouseout="this.style.background='var(--gray-light)'; this.style.color='var(--text)'">Facebook</a>
      <a href="https://www.linkedin.com/shareArticle?mini=true&url=<%= encodeURIComponent('https://halo.pl/blog/' + post.slug) %>&title=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener" style="padding:10px 20px; background:var(--gray-light); font-size:13px; font-weight:600; text-decoration:none; color:var(--text); transition:background .2s;" onmouseover="this.style.background='var(--red)'; this.style.color='white'" onmouseout="this.style.background='var(--gray-light)'; this.style.color='var(--text)'">LinkedIn</a>
    </div>

    <!-- Author box -->
    <div style="margin-top:40px; background:var(--gray-light); padding:32px 36px; display:flex; align-items:center; gap:28px; border-left:4px solid var(--red);">
      <img src="/images/kamil_11.png" alt="Kamil" style="width:72px; height:72px; object-fit:cover; object-position:top; border-radius:50%; flex-shrink:0;">
      <div>
        <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:4px;">Autor</div>
        <div style="font-size:17px; font-weight:700; color:var(--black); margin-bottom:6px;">Kamil — Halo</div>
        <p style="font-size:14px; color:var(--gray); line-height:1.6;">Specjalista digital marketingu. Pomagam firmom z Tarnobrzega, Sandomierza, Stalowej Woli, Nowej Dęby, Mielca i okolic zdobywać klientów przez internet.</p>
      </div>
    </div>
  </div>
</section>

<!-- RELATED POSTS -->
<% if (related.length > 0) { %>
<section style="background:var(--gray-light); padding:80px 60px;">
  <div class="section-inner">
    <h2 style="font-family:var(--font-display); font-size:40px; color:var(--black); margin-bottom:40px;">Powiązane <em style="color:var(--red); font-style:normal;">artykuły</em></h2>
    <div style="display:grid; grid-template-columns:repeat(<%= related.length %>,1fr); gap:28px;">
      <% for (const rp of related) { %>
        <a href="/blog/<%= rp.slug %>" style="text-decoration:none; background:white; padding:32px; border-top:3px solid transparent; transition:border-color .25s; display:block;" onmouseover="this.style.borderColor='var(--red)'" onmouseout="this.style.borderColor='transparent'" class="fade-in">
          <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:8px;">
            <%= new Date(rp.created_at).toLocaleDateString('pl-PL', { year:'numeric', month:'long', day:'numeric' }) %>
          </div>
          <h3 style="font-size:18px; font-weight:700; color:var(--black); margin-bottom:8px; line-height:1.3;"><%= rp.title %></h3>
          <span style="font-size:13px; color:var(--red); font-weight:600;">Czytaj →</span>
        </a>
      <% } %>
    </div>
  </div>
</section>
<% } %>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-inner">
    <div class="section-label">Porozmawiajmy</div>
    <h2 class="cta-title">Opowiedz mi o swoich<br><em>wyzwaniach</em></h2>
    <p class="cta-sub">Razem znajdziemy rozwiązanie. Bezpłatna konsultacja, bez zobowiązań.</p>
    <div class="cta-btns">
      <a href="/kontakt" class="btn-primary">Umów konsultację</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
<script src="/js/extra.js"></script>
</body>
</html>
