<%- include('partials/head', { title: 'Mapa strony — Halo', settings }) %>
<% const currentPage = ''; %>
<%- include('partials/nav') %>

<section style="background:var(--black); padding:140px 60px 80px;">
  <div class="section-inner" style="max-width:900px;">
    <div style="font-size:11px; letter-spacing:4px; text-transform:uppercase; color:var(--red); margin-bottom:16px; display:flex; align-items:center; gap:12px;">
      <span style="width:32px; height:2px; background:var(--red); display:block;"></span>
      Nawigacja
    </div>
    <h1 style="font-family:var(--font-display); font-size:clamp(48px,6vw,88px); color:white; line-height:0.95;">Mapa <em style="color:var(--red); font-style:normal;">strony</em></h1>
  </div>
</section>

<section style="background:white; padding:80px 60px;">
  <div class="section-inner" style="max-width:1000px;">

    <!-- STRONY GŁÓWNE -->
    <div style="margin-bottom:60px;">
      <h2 style="font-size:13px; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:24px; padding-bottom:12px; border-bottom:2px solid var(--red);">Strony główne</h2>
      <ul style="list-style:none; display:grid; grid-template-columns:repeat(3,1fr); gap:8px;">
        <% [
          ['/','Strona główna'],['/o-mnie','O mnie'],['/realizacje','Realizacje'],
          ['/blog','Blog'],['/kontakt','Kontakt'],['/lokalizacje','Obsługiwane lokalizacje']
        ].forEach(([href,label]) => { %>
          <li><a href="<%= href %>" style="font-size:14px; color:var(--text); text-decoration:none; display:block; padding:8px 0; border-bottom:1px solid #f0f0f0; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
        <% }); %>
      </ul>
    </div>

    <!-- TARNOBRZEG — USŁUGI GŁÓWNE -->
    <div style="margin-bottom:60px;">
      <h2 style="font-size:13px; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:24px; padding-bottom:12px; border-bottom:2px solid var(--red);">
        <a href="/tarnobrzeg" style="color:var(--red); text-decoration:none;">Tarnobrzeg</a> — usługi główne
      </h2>
      <ul style="list-style:none; display:grid; grid-template-columns:repeat(3,1fr); gap:8px;">
        <% [
          ['/tarnobrzeg/strony-internetowe','Strony internetowe'],
          ['/tarnobrzeg/seo','SEO — pozycjonowanie'],
          ['/tarnobrzeg/google-ads','Google Ads'],
          ['/tarnobrzeg/grafika-reklamowa','Grafika i branding'],
          ['/tarnobrzeg/automatyzacje','Automatyzacje firmowe'],
          ['/tarnobrzeg/marketing-internetowy','Marketing internetowy'],
          ['/tarnobrzeg/social-media','Social media'],
          ['/tarnobrzeg/content-marketing','Content marketing'],
          ['/tarnobrzeg/analityka-doradztwo','Analityka i doradztwo'],
          ['/tarnobrzeg/sklep-internetowy','Sklep internetowy'],
        ].forEach(([href,label]) => { %>
          <li><a href="<%= href %>" style="font-size:14px; color:var(--text); text-decoration:none; display:block; padding:8px 0; border-bottom:1px solid #f0f0f0; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
        <% }); %>
      </ul>
    </div>

    <!-- TARNOBRZEG — PODSTRONY LEVEL 3 -->
    <div style="margin-bottom:60px;">
      <h2 style="font-size:13px; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:32px; padding-bottom:12px; border-bottom:2px solid var(--red);">Tarnobrzeg — podstrony szczegółowe</h2>
      <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:40px;">

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Strony internetowe</h3>
          <ul style="list-style:none;">
            <% [
              ['projekt-graficzny-strony','Projekt graficzny strony'],
              ['responsywny-kod-mobile','Responsywna strona mobilna'],
              ['seo-on-page','SEO on-page'],
              ['schema-markup','Schema markup'],
              ['core-web-vitals','Core Web Vitals'],
              ['integracja-narzedzi-analitycznych','Integracja narzędzi analitycznych'],
              ['panel-administracyjny','Panel administracyjny'],
              ['ssl-hosting-kopie-zapasowe','SSL, hosting i kopie zapasowe'],
              ['formularze-kontaktowe','Formularze kontaktowe'],
              ['automatyzacja-follow-up-po-formularzu','Automatyzacja follow-up'],
              ['optymalizacja-pod-generative-search','Optymalizacja pod Generative Search'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/strony-internetowe/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">SEO</h3>
          <ul style="list-style:none;">
            <% [
              ['audyt-seo','Audyt SEO'],
              ['analiza-konkurencji-lokalnej','Analiza konkurencji lokalnej'],
              ['google-business-profile','Google Business Profile'],
              ['lokalne-slowa-kluczowe','Lokalne słowa kluczowe'],
              ['optymalizacja-techniczna-strony','Optymalizacja techniczna'],
              ['tworzenie-tresci-seo','Tworzenie treści SEO'],
              ['landing-page-lokalne','Landing page lokalne'],
              ['link-building-lokalny','Link building lokalny'],
              ['zarzadzanie-opiniami-google','Zarządzanie opiniami Google'],
              ['raport-seo-miesieczny','Raport SEO miesięczny'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/seo/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Google Ads</h3>
          <ul style="list-style:none;">
            <% [
              ['audyt-konta-google-ads','Audyt konta Google Ads'],
              ['konfiguracja-nowego-konta-google-ads','Konfiguracja konta'],
              ['badanie-slow-kluczowych','Badanie słów kluczowych'],
              ['kreacje-reklamowe-google-ads','Kreacje reklamowe'],
              ['targetowanie-lokalne-google-ads','Targetowanie lokalne'],
              ['sledzenie-konwersji-google-ads','Śledzenie konwersji'],
              ['optymalizacja-kampanii-google-ads','Optymalizacja kampanii'],
              ['remarketing-google-ads','Remarketing'],
              ['raport-google-ads-roas','Raport i ROAS'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/google-ads/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Grafika i branding</h3>
          <ul style="list-style:none;">
            <% [
              ['logo-i-identyfikacja-wizualna','Logo i identyfikacja wizualna'],
