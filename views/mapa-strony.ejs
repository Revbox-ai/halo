              ['prezentacje-firmowe','Prezentacje firmowe'],
              ['grafiki-na-strone-internetowa','Grafiki na stronę'],
              ['brandbook','Brandbook'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/grafika-reklamowa/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Automatyzacje</h3>
          <ul style="list-style:none;">
            <% [
              ['audyt-procesow','Audyt procesów'],
              ['make-zapier','Make i Zapier'],
              ['chatboty-ai','Chatboty AI'],
              ['follow-up-email-sms','Follow-up email i SMS'],
              ['integracje-crm','Integracje CRM'],
              ['automatyzacja-fakturowania','Automatyzacja fakturowania'],
              ['powiadomienia-i-alerty','Powiadomienia i alerty'],
              ['szkolenie-z-obslugi-systemow','Szkolenie z obsługi systemów'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/automatyzacje/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Marketing internetowy</h3>
          <ul style="list-style:none;">
            <% [
              ['facebook-instagram-ads','Facebook i Instagram Ads'],
              ['tiktok-ads','TikTok Ads'],
              ['linkedin-ads','LinkedIn Ads'],
              ['planowanie-kampanii','Planowanie kampanii'],
              ['dobor-kanalow-marketingowych','Dobór kanałów'],
              ['kreacje-reklamowe','Kreacje reklamowe'],
              ['pixele-konwersje-sledzenie','Piksele i konwersje'],
              ['analiza-i-raport-miesieczny','Analiza miesięczna'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/marketing-internetowy/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Social media</h3>
          <ul style="list-style:none;">
            <% [
              ['prowadzenie-profili-firmowych','Prowadzenie profili'],
              ['posty-grafiki-rolki-stories','Posty, rolki i stories'],
              ['kalendarz-tresci','Kalendarz treści'],
              ['obsluga-komentarzy-i-wiadomosci','Obsługa komentarzy'],
              ['zasiegi-organiczne','Zasięgi organiczne'],
              ['kampanie-reklamowe-social-media','Kampanie reklamowe'],
              ['raport-social-media','Raport social media'],
              ['komunikacja-dopasowana-do-platformy','Komunikacja per platforma'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/social-media/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Content marketing</h3>
          <ul style="list-style:none;">
            <% [
              ['strategia-contentowa','Strategia contentowa'],
              ['teksty-na-strony-uslugowe','Teksty na strony usługowe'],
              ['artykuly-blogowe-seo','Artykuły blogowe SEO'],
              ['opisy-produktow-i-kategorii','Opisy produktów'],
              ['newslettery-i-sekwencje-email','Newslettery i email'],
              ['ebooki-checklisty-przewodniki','E-booki i checklisty'],
              ['copywriting-storytelling','Copywriting i storytelling'],
              ['optymalizacja-tresci-pod-seo','Optymalizacja treści'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/content-marketing/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Analityka i doradztwo</h3>
          <ul style="list-style:none;">
            <% [
              ['konfiguracja-ga4-gtm','Konfiguracja GA4 i GTM'],
              ['sledzenie-konwersji','Śledzenie konwersji'],
              ['audyt-dzialan-marketingowych','Audyt działań'],
              ['raporty-z-rekomendacjami','Raporty z rekomendacjami'],
              ['testy-ab','Testy A/B'],
              ['analiza-lejka-sprzedazowego','Analiza lejka'],
              ['doradztwo-strategiczne','Doradztwo strategiczne'],
              ['konsultacje-godzinowe','Konsultacje godzinowe'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/analityka-doradztwo/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

        <div>
          <h3 style="font-size:12px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:12px;">Sklep internetowy</h3>
          <ul style="list-style:none;">
            <% [
              ['wdrozenie-woocommerce-prestashop','Wdrożenie WooCommerce / PrestaShop'],
              ['projekt-graficzny-sklepu','Projekt graficzny sklepu'],
              ['optymalizacja-konwersji-cro','Optymalizacja konwersji CRO'],
              ['integracja-systemow-platnosci','Integracja płatności'],
              ['feed-produktowy-google-merchant','Feed Google Merchant'],
              ['seo-sklepu-internetowego','SEO sklepu'],
              ['reklamy-google-shopping','Google Shopping'],
              ['audyt-optymalizacja-sklepu','Audyt sklepu'],
            ].forEach(([sub,label]) => { %>
              <li><a href="/tarnobrzeg/sklep-internetowy/<%= sub %>" style="font-size:13px; color:var(--text); text-decoration:none; display:block; padding:6px 0; border-bottom:1px solid #f5f5f5; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
            <% }); %>
          </ul>
        </div>

      </div>
    </div>

    <!-- INNE LOKALIZACJE -->
    <div>
      <h2 style="font-size:13px; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:24px; padding-bottom:12px; border-bottom:2px solid var(--red);">Inne obsługiwane lokalizacje</h2>
      <ul style="list-style:none; display:grid; grid-template-columns:repeat(3,1fr); gap:8px;">
        <% [
          ['/stalowa-wola/strony-internetowe','Strony internetowe Stalowa Wola'],
          ['/stalowa-wola/seo','SEO Stalowa Wola'],
          ['/stalowa-wola/google-ads','Google Ads Stalowa Wola'],
          ['/sandomierz/strony-internetowe','Strony internetowe Sandomierz'],
          ['/sandomierz/seo','SEO Sandomierz'],
          ['/sandomierz/google-ads','Google Ads Sandomierz'],
          ['/mielec/strony-internetowe','Strony internetowe Mielec'],
          ['/mielec/seo','SEO Mielec'],
          ['/mielec/google-ads','Google Ads Mielec'],
          ['/rzeszow/strony-internetowe','Strony internetowe Rzeszów'],
          ['/rzeszow/seo','SEO Rzeszów'],
          ['/rzeszow/google-ads','Google Ads Rzeszów'],
          ['/nowa-deba/strony-internetowe','Strony internetowe Nowa Dęba'],
        ].forEach(([href,label]) => { %>
          <li><a href="<%= href %>" style="font-size:14px; color:var(--text); text-decoration:none; display:block; padding:8px 0; border-bottom:1px solid #f0f0f0; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text)'"><%= label %></a></li>
