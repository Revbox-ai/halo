<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-label">Cyfrowa agencja nowych technologii</div>
      <h1>Pomagamy firmom<br>z <em>Tarnobrzega</em><br>zdobywać<br><em>klientów</em></h1>
      <p class="hero-sub">Automatyzacje, Strony internetowe, SEO, Google Ads. Działamy lokalnie — rozumiemy tutejszy rynek.</p>
      <div class="hero-btns">
        <a href="/kontakt" class="btn-primary">Umów bezpłatną konsultację</a>
        <a href="/realizacje" class="btn-secondary">Zobacz realizacje</a>
      </div>
    </div>
    <div class="hero-visual">
      <img src="/images/header.png" alt="Halo — marketing cyfrowy Tarnobrzeg" class="hero-img" style="border-radius:4px; max-height:520px; object-fit:cover;">
    </div>
  </div>
  <div class="scroll-indicator">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- LOGOS BAR -->
<div class="logos-bar">
  <div class="logos-inner">
    <span class="logos-label">Zaufali nam</span>
    <span class="logo-item">MaxDent</span>
    <span class="logo-item">Murarz</span>
    <span class="logo-item">Aura Salon</span>
