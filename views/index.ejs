        <div style="margin-bottom:20px;">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2">
            <rect x="4" y="10" width="32" height="22" rx="2"/>
            <path d="M12 10V8a4 4 0 0 1 8 0v2"/>
            <path d="M20 10V8a4 4 0 0 1 8 0v2"/>
