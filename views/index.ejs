      <div class="fade-in" style="background:white; padding:40px 32px; border-left:4px solid var(--red);">
        <div style="margin-bottom:20px;">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2">
            <circle cx="20" cy="20" r="14"/>
            <path d="M20 6v14l8 5"/>
            <line x1="20" y1="4" x2="20" y2="2"/>
            <line x1="32" y1="8" x2="34" y2="6"/>
            <line x1="36" y1="20" x2="38" y2="20"/>
