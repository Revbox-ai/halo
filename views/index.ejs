<!-- REALIZACJE -->
<section style="background:white; padding:100px 60px;" id="realizacje">
  <div class="section-inner">
    <div class="section-label fade-in">Efekty pracy</div>
    <h2 class="section-title fade-in">Realizacje i<br><em>wyniki</em></h2>
    <div style="display:grid; grid-template-columns: repeat(<%= Math.min(realizacje.length, 3) %>, 1fr); gap:28px; margin-top:60px;">
      <% for (const r of realizacje) { %>
        <% let efektyArr = []; try { efektyArr = JSON.parse(r.efekty || '[]'); } catch(e) {} %>
        <a href="/realizacje/<%= r.slug %>" style="text-decoration:none;" class="fade-in">
          <div style="border:1px solid #eee; transition:box-shadow .25s, transform .25s;" onmouseover="this.style.boxShadow='0 16px 48px rgba(0,0,0,0.1)'; this.style.transform='translateY(-4px)'" onmouseout="this.style.boxShadow='none'; this.style.transform='translateY(0)'">
            <div style="background:var(--black); padding:28px 32px;">
              <div style="font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:8px;"><%= r.branza %></div>
              <h3 style="font-size:20px; font-weight:700; color:white; margin-bottom:4px;"><%= r.title %></h3>
              <div style="font-size:13px; color:rgba(255,255,255,0.4);">📍 <%= r.miasto %></div>
            </div>
            <div style="padding:28px 32px;">
              <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--gray); margin-bottom:8px;">Problem</div>
              <p style="font-size:14px; color:var(--text); line-height:1.6; margin-bottom:20px;"><%= r.problem.substring(0,100) %>...</p>
              <% if (efektyArr.length > 0) { %>
                <div style="background:var(--gray-light); padding:16px; border-left:3px solid var(--red);">
                  <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--red); margin-bottom:8px;">Efekt</div>
                  <p style="font-size:14px; font-weight:600; color:var(--black);"><%= efektyArr[0] %></p>
                </div>
              <% } %>
            </div>
          </div>
        </a>
      <% } %>
    </div>
    <div style="text-align:center; margin-top:48px;">
      <a href="/realizacje" class="btn-primary">Zobacz wszystkie realizacje</a>
    </div>
  </div>
</section>

<!-- OPINIE -->
<section class="testimonials" id="opinie">
  <div class="section-inner">
    <div class="section-label fade-in">Opinie klientów</div>
    <h2 class="section-title fade-in">Co mówią o <em>współpracy</em></h2>
    <div class="testimonials-grid">
      <% for (const o of opinie) { %>
        <div class="testimonial-card fade-in">
          <div class="testimonial-quote">"</div>
          <p class="testimonial-text"><%= o.tresc %></p>
          <div class="testimonial-author">
            <div class="testimonial-avatar"><%= o.inicjaly || o.imie.substring(0,2).toUpperCase() %></div>
            <div>
              <div class="testimonial-name"><%= o.imie %></div>
              <% if (o.firma) { %><div class="testimonial-company"><%= o.firma %></div><% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- WYNIKI LICZBOWE -->
<section class="results">
  <div class="results-inner">
    <div class="fade-in">
      <div class="result-num">480<span style="font-size:40px">+</span></div>
      <div class="result-label">Projektów</div>
    </div>
    <div class="fade-in">
      <div class="result-num">18</div>
      <div class="result-label">Lat doświadczenia</div>
    </div>
    <div class="fade-in">
      <div class="result-num">100<span style="font-size:40px">%</span></div>
      <div class="result-label">Zadowolonych klientów</div>
    </div>
    <div class="fade-in">
      <div class="result-num">3x</div>
      <div class="result-label">Średni wzrost zapytań</div>
    </div>
  </div>
</section>

<!-- DLACZEGO HALO -->
<section style="background:var(--black); padding:100px 60px;" id="dlaczego">
  <div class="section-inner">
    <div class="section-label fade-in">Przewaga</div>
    <h2 class="section-title fade-in" style="color:white;">Dlaczego <em>Halo</em>,<br>nie zwykła agencja?</h2>
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:3px; margin-top:60px;">

      <div class="fade-in" style="background:#111; padding:44px 40px;">
        <div style="font-family:var(--font-display); font-size:48px; color:var(--red); line-height:1; margin-bottom:16px;">01</div>
        <h3 style="font-size:18px; font-weight:700; color:white; margin-bottom:12px;">Lokalność jako atut</h3>
        <p style="font-size:14px; line-height:1.7; color:rgba(255,255,255,0.5);">Jesteśmy stąd — z Tarnobrzega, Sandomierza, Stalowej Woli i okolic. Znamy tutejszy rynek i wiemy, jak myśli lokalny klient. Duże agencje z Warszawy tego nie wiedzą.</p>
      </div>

      <div class="fade-in" style="background:#111; padding:44px 40px;">
        <div style="font-family:var(--font-display); font-size:48px; color:var(--red); line-height:1; margin-bottom:16px;">02</div>
        <h3 style="font-size:18px; font-weight:700; color:white; margin-bottom:12px;">Płacisz za efekty, nie za obecność</h3>
        <p style="font-size:14px; line-height:1.7; color:rgba(255,255,255,0.5);">Rozliczamy się z konkretnych wyników: pozycji, leadów, konwersji. Nie za godziny pracy anonimowych juniorów w open space.</p>
      </div>

      <div class="fade-in" style="background:#111; padding:44px 40px;">
        <div style="font-family:var(--font-display); font-size:48px; color:var(--red); line-height:1; margin-bottom:16px;">03</div>
        <h3 style="font-size:18px; font-weight:700; color:white; margin-bottom:12px;">Jeden opiekun — pełna wiedza</h3>
        <p style="font-size:14px; line-height:1.7; color:rgba(255,255,255,0.5);">Rozmawiasz z jedną osobą, która zna Twój projekt od A do Z. Koniec z „przełączam do działu" i tłumaczeniem wszystkiego od nowa.</p>
      </div>

      <div class="fade-in" style="background:#111; padding:44px 40px;">
        <div style="font-family:var(--font-display); font-size:48px; color:var(--red); line-height:1; margin-bottom:16px;">04</div>
        <h3 style="font-size:18px; font-weight:700; color:white; margin-bottom:12px;">Szybkość i elastyczność</h3>
        <p style="font-size:14px; line-height:1.7; color:rgba(255,255,255,0.5);">Małe agencje działają szybciej. Nie mamy biurokracji ani 3-tygodniowych harmonogramów akceptacji. Reagujemy tego samego dnia.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROCES WSPÓŁPRACY -->
<section class="process" id="proces">
  <div class="section-inner">
    <div class="section-label fade-in">Jak działamy</div>
    <h2 class="section-title fade-in">Proces <em>współpracy</em></h2>
    <div class="process-grid">
      <div class="process-step fade-in">
        <div class="process-num">1</div>
        <h4>Bezpłatna konsultacja</h4>
        <p>Omawiamy Twój cel, rynek i budżet. Bez zobowiązań, bez ściemy.</p>
      </div>
      <div class="process-step fade-in">
        <div class="process-num">2</div>
        <h4>Analiza i strategia</h4>
        <p>Badamy konkurencję i przygotowujemy konkretny plan działania.</p>
      </div>
      <div class="process-step fade-in">
        <div class="process-num">3</div>
        <h4>Wdrożenie</h4>
        <p>Realizujemy projekt zgodnie z harmonogramem i budżetem.</p>
      </div>
      <div class="process-step fade-in">
        <div class="process-num">4</div>
        <h4>Optymalizacja</h4>
        <p>Mierzymy efekty i stale poprawiamy wyniki — nie spoczywamy na laurach.</p>
      </div>
      <div class="process-step fade-in">
        <div class="process-num">5</div>
        <h4>Raport i skalowanie</h4>
        <p>Comiesięczny raport + propozycje kolejnych kroków rozwoju.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section style="background:var(--gray-light); padding:100px 60px;" id="faq">
  <div class="section-inner" style="max-width:800px;">
    <div class="section-label fade-in">FAQ</div>
    <h2 class="section-title fade-in">Najczęstsze<br><em>pytania</em></h2>
    <div style="margin-top:60px;">
      <% const faqs = [
        { q: 'Ile kosztuje współpraca z Halo?', a: 'Zależy od zakresu usług. Strona internetowa to od 1500 zł, kampania Google Ads od 499 zł/mies. + budżet mediowy, SEO od 799 zł/mies. Każda wycena jest indywidualna.' },
        { q: 'Czy musisz pracować w Tarnobrzega?', a: 'Nie. Pracuję zdalnie z klientami z całego regionu — Sandomierz, Stalowa Wola, Nowa Dęba, Mielec, Rzeszów i okolice. Spotkania offline możliwe na terenie Tarnobrzega i okolic.' },
        { q: 'Jak szybko zobaczę efekty?', a: 'Google Ads działa od pierwszego dnia. SEO i strony dają efekty po 2–4 miesiącach. Grafika i automatyzacja — od razu po wdrożeniu.' },
        { q: 'Czy mogę zacząć od jednej usługi?', a: 'Tak, absolutnie. Większość klientów zaczyna od jednego projektu, a potem rozszerza współpracę o kolejne usługi.' },
        { q: 'Co jeśli nie jestem zadowolony z efektów?', a: 'Zawsze rozmawiamy otwarcie. Jeśli coś nie działa, szukamy przyczyny i zmieniamy podejście. Zależy mi na długotrwałej relacji, nie na jednorazowej transakcji.' },
        { q: 'Czy muszę podpisywać długoterminową umowę?', a: 'Nie. Pracuję na umowach miesięcznych lub projektowych. Jedynym wyjątkiem jest SEO — tu efekty są po 3–6 miesiącach, więc zalecam min. 6-miesięczny kontrakt.' }
      ]; %>
      <% for (let i = 0; i < faqs.length; i++) { %>
        <div class="faq-item fade-in" onclick="this.classList.toggle('open')">
          <div class="faq-question">
            <span><%= faqs[i].q %></span>
            <span class="faq-icon">+</span>
          </div>
          <div class="faq-answer"><%= faqs[i].a %></div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- KONTAKT -->
<section style="background:var(--red); padding:100px 60px;" id="kontakt">
  <div class="section-inner" style="max-width:1000px; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start;">
    <div class="fade-in">
      <div class="section-label section-label-white" style="color:rgba(255,255,255,0.7);">Skontaktuj się</div>
      <h2 class="section-title" style="color:white; margin-bottom:28px;">Porozmawiajmy<br>o Twoim <em>projekcie</em></h2>
      <div style="margin-bottom:32px;">
        <a href="tel:<%= settings.phone %>" style="display:flex; align-items:center; gap:16px; margin-bottom:20px; text-decoration:none; color:white; transition:opacity .2s;" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
          <div style="width:48px; height:48px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; font-size:18px; color:white;"><i class="fa-solid fa-phone"></i></div>
          <div>
            <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:4px;">Telefon</div>
            <div style="font-size:16px; font-weight:600;"><%= settings.phone %></div>
          </div>
        </a>
        <a href="mailto:<%= settings.email %>" style="display:flex; align-items:center; gap:16px; margin-bottom:20px; text-decoration:none; color:white; transition:opacity .2s;" onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
          <div style="width:48px; height:48px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; font-size:18px; color:white;"><i class="fa-solid fa-envelope"></i></div>
          <div>
            <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:4px;">E-mail</div>
            <div style="font-size:16px; font-weight:600;"><%= settings.email %></div>
          </div>
        </a>
        <div style="display:flex; align-items:center; gap:16px;">
          <div style="width:48px; height:48px; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; font-size:18px; color:white;"><i class="fa-solid fa-location-dot"></i></div>
          <div>
            <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:4px;">Lokalizacja</div>
            <div style="font-size:16px; font-weight:600; color:white;"><%= settings.address %></div>
          </div>
        </div>
      </div>
      <div style="background:rgba(255,255,255,0.15); padding:20px 24px; border-left:3px solid white;">
        <p style="font-size:14px; color:rgba(255,255,255,0.85);"><i class="fa-regular fa-clock" style="margin-right:6px;"></i><strong>Czas odpowiedzi: do 24h</strong><br>Zazwyczaj odpowiadam tego samego dnia roboczego.</p>
      </div>
    </div>
    <div class="fade-in">
      <form action="/kontakt" method="POST">
        <div style="margin-bottom:16px;">
          <label style="display:block; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:8px;">Imię i nazwisko *</label>
          <input type="text" name="name" required style="width:100%; padding:14px 18px; border:1px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.15); color:white; font-size:15px; font-family:var(--font-body); outline:none; transition:border-color .2s;" onfocus="this.style.borderColor='white'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'">
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:8px;">E-mail *</label>
          <input type="email" name="email" required style="width:100%; padding:14px 18px; border:1px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.15); color:white; font-size:15px; font-family:var(--font-body); outline:none; transition:border-color .2s;" onfocus="this.style.borderColor='white'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'">
        </div>
        <div style="margin-bottom:16px;">
          <label style="display:block; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.7); margin-bottom:8px;">Wiadomość</label>
          <textarea name="message" rows="4" style="width:100%; padding:14px 18px; border:1px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.15); color:white; font-size:15px; font-family:var(--font-body); outline:none; transition:border-color .2s; resize:vertical;" onfocus="this.style.borderColor='white'" onblur="this.style.borderColor='rgba(255,255,255,0.3)'"></textarea>
        </div>
        <button type="submit" style="width:100%; background:white; color:var(--red); font-size:13px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; padding:18px; border:none; cursor:pointer; font-family:var(--font-body); transition:background .2s;" onmouseover="this.style.background='#f0f0f0'" onmouseout="this.style.background='white'">Wyślij wiadomość →</button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
<script src="/js/extra.js"></script>
</body>
</html>
