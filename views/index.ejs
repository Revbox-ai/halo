        <div style="margin-bottom:20px;">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2">
            <rect x="6" y="18" width="28" height="18" rx="1"/>
            <path d="M12 18V12a8 8 0 0 1 16 0v6"/>
            <line x1="14" y1="26" x2="26" y2="26"/>
