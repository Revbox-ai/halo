        <ul style="list-style:none; font-size:13px; color:var(--gray);">
          <li style="padding:4px 0; border-bottom:1px solid #eee;">✓ Sklep internetowy</li>
          <li style="padding:4px 0; border-bottom:1px solid #eee;">✓ Google Shopping</li>
