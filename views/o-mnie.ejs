<%- include('partials/head', { title, settings }) %>
<% const currentPage = 'o-mnie'; %>
<%- include('partials/nav') %>

<!-- HERO -->
<section class="hero" style="min-height:70vh; padding:120px 60px 80px;">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-label">O mnie</div>
      <h1>Nowe technologie,<br>marketing, <em>efekty.</em></h1>
      <p class="hero-sub">Za pomocą nowoczesnych technologii pomagam firmom z regionu zdobywać klientów. Bez korporacyjnych procedur, z pełnym zaangażowaniem w Twój sukces.</p>
      <div class="hero-btns">
        <a href="/kontakt" class="btn-primary">Umów konsultację</a>
        <a href="/realizacje" class="btn-secondary">Moje realizacje</a>
      </div>
    </div>
    <div class="hero-visual">
      <img src="/images/kamil_2.png" alt="Kamil — Halo agencja Tarnobrzeg" class="hero-img" style="border-radius:4px; width:100%; height:auto; object-fit:unset;">
    </div>
  </div>
</section>

<!-- STATS BAR -->
<section class="results">
  <div class="results-inner">
    <div><div class="result-num">480<span style="font-size:40px">+</span></div><div class="result-label">Projektów</div></div>
    <div><div class="result-num">18</div><div class="result-label">Lat w branży</div></div>
    <div><div class="result-num">100<span style="font-size:40px">%</span></div><div class="result-label">Zadowolonych klientów</div></div>
    <div><div class="result-num">6</div><div class="result-label">Obszarów specjalizacji</div></div>
  </div>
</section>

<!-- BIO -->
<section style="background:white; padding:100px 60px;">
  <div class="section-inner" style="max-width:1000px; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start;">
    <div class="fade-in">
      <div class="section-label">Kim jestem</div>
      <h2 class="section-title" style="margin-bottom:28px;">Przedsiębiorca,<br>który rozumie <em>Twoje</em> potrzeby</h2>
      <p style="font-size:15px; line-height:1.8; color:#444; margin-bottom:20px;">
        Sam byłem na Twoim miejscu. Prowadziłem własny sklep e-commerce, tworzyłem startupy, budowałem marki od zera, inwestowałem w reklamy i SEO, które nie przynosiły efektów. Wiem, jak boli przepalony budżet i jak smakuje pierwszy klient pozyskany z internetu. Dlatego nie sprzedaję usług, tylko szukam rozwiązań, które naprawdę działają.
      </p>
      <p style="font-size:15px; line-height:1.8; color:#444; margin-bottom:20px;">
        Jako założyciel własnej agencji reklamowej i kreatywnej realizowałem projekty dla największych światowych marek. Współpracowałem z agencją Havas, jedną z największych warszawskich agencji mediowych, jako partner kreatywny przy kampaniach dla takich marek jak Coca-Cola, Adidas, Hyundai, Kia, Reebok, T-Mobile i Polpharma. Odpowiadałem za koncepcję, kreację oraz relacje biznesowe, działając zgodnie z międzynarodowymi standardami.
      </p>
      <p style="font-size:15px; line-height:1.8; color:#444;">
        Dziś, jako twórca agencji Halo, łączę doświadczenie zdobyte przy pracy z dużymi markami z głębokim zrozumieniem potrzeb lokalnych przedsiębiorców oraz znajomością najnowszych technologii. Jesteś u mnie w dobrych rękach, bo znam ten biznes od środka.
      </p>
    </div>
    <div class="fade-in">
      <img src="/images/kamil_11.png" alt="Kamil w pracy" style="width:100%; object-fit:cover; object-position:top; display:block;">
    </div>
  </div>
</section>

<!-- MARKI -->
<section style="background:var(--black); padding:60px 60px;">
  <div class="section-inner">
    <p class="fade-in" style="font-size:11px; letter-spacing:3px; text-transform:uppercase; color:rgba(255,255,255,0.35); margin-bottom:36px; text-align:center;">Marki, dla których tworzyłem</p>
    <div class="fade-in" style="display:flex; align-items:center; justify-content:center; gap:48px; flex-wrap:wrap;">
      <img src="/images/brands/logo-cocacola.png" alt="Coca-Cola" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
      <img src="/images/brands/logo-adidas.png" alt="Adidas" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
      <img src="/images/brands/logo-reebok.png" alt="Reebok" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
      <img src="/images/brands/logo-hyundai.png" alt="Hyundai" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
      <img src="/images/brands/logo-kia.png" alt="Kia" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
      <img src="/images/brands/logo-tmobile.png" alt="T-Mobile" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
      <img src="/images/brands/logo-polpharma.png" alt="Polpharma" style="height:36px; object-fit:contain; filter:grayscale(1); opacity:.5; transition:opacity .3s;" onmouseover="this.style.opacity='1'; this.style.filter='grayscale(0)'" onmouseout="this.style.opacity='.5'; this.style.filter='grayscale(1)'">
    </div>
  </div>
</section>

<!-- PODCAST -->
<section style="background:#f5f5f5; padding:100px 60px;">
  <div class="section-inner" style="max-width:1000px; display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center;">
    <div class="fade-in">
      <div class="section-label">Podcast biznesowy</div>
      <h2 class="section-title" style="margin-bottom:24px;">Druga Strona<br><em>Sukcesu</em></h2>
      <p style="font-size:15px; line-height:1.8; color:#555; margin-bottom:20px;">Prowadzę podcast biznesowy, w którym rozmawiam z przedsiębiorcami, liderami i ekspertami o strategiach, wytrwałości i prawdziwej cenie sukcesu. Bez filtrów, bez owijania w bawełnę.</p>
      <p style="font-size:15px; line-height:1.8; color:#555; margin-bottom:36px;">Bo każdy sukces ma swoją nieopowiedzianą historię — i właśnie ją staram się wyciągnąć na światło dzienne.</p>
      <div style="display:flex; gap:16px; flex-wrap:wrap;">
        <a href="https://www.youtube.com/channel/UCf5orEhZ7UDEVFh_I3llAkQ" target="_blank" rel="noopener" class="btn-primary"><i class="fa-brands fa-youtube" style="margin-right:8px;"></i>Posłuchaj podcastu</a>
        <a href="https://www.drugastronasukcesu.pl/" target="_blank" rel="noopener" class="btn-secondary" style="border-color:rgba(0,0,0,0.2); color:#444;">Zobacz stronę podcastu</a>
      </div>
      <div style="margin-top:36px; display:flex; gap:20px; align-items:center;">
        <span style="font-size:11px; letter-spacing:3px; text-transform:uppercase; color:#aaa;">Dostępny na</span>
        <span style="font-size:13px; color:#aaa; display:flex; gap:16px; align-items:center;">
          <a href="https://www.youtube.com/channel/UCf5orEhZ7UDEVFh_I3llAkQ" target="_blank" rel="noopener" style="color:#aaa; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='#aaa'"><i class="fa-brands fa-youtube" style="font-size:18px;"></i></a>
          <a href="https://open.spotify.com/show/4bDbax7y7e6SZ4vgyC9IHo" target="_blank" rel="noopener" style="color:#aaa; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='#aaa'"><i class="fa-brands fa-spotify" style="font-size:18px;"></i></a>
          <a href="https://facebook.com/drugastronasukcesu" target="_blank" rel="noopener" style="color:#aaa; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='#aaa'"><i class="fa-brands fa-facebook" style="font-size:18px;"></i></a>
          <a href="https://instagram.com/drugastronasukcesu" target="_blank" rel="noopener" style="color:#aaa; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='#aaa'"><i class="fa-brands fa-instagram" style="font-size:18px;"></i></a>
          <a href="https://tiktok.com/@drugastronasukcesu" target="_blank" rel="noopener" style="color:#aaa; transition:color .2s;" onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='#aaa'"><i class="fa-brands fa-tiktok" style="font-size:18px;"></i></a>
        </span>
      </div>
    </div>
    <div class="fade-in" style="background:white; border:1px solid #e8e8e8; padding:40px; position:relative;">
      <div style="position:absolute; top:-20px; left:40px; font-family:var(--font-display); font-size:80px; color:var(--red); line-height:1;">"</div>
      <p style="font-size:18px; line-height:1.7; color:var(--black); font-style:italic; margin-top:24px;">Rozmawiam z ludźmi, którym się udało — ale pytam ich o to, czego nie pokazują na Instagramie.</p>
      <div style="margin-top:28px; padding-top:24px; border-top:1px solid #eee; font-size:12px; letter-spacing:2px; text-transform:uppercase; color:#aaa;">Kamil Pionkowski · Druga Strona Sukcesu</div>
    </div>
  </div>
</section>

<!-- KOMPETENCJE -->
<section style="background:white; padding:100px 60px;">
  <div class="section-inner">
    <div class="section-label fade-in">Specjalizacje</div>
    <h2 class="section-title fade-in">Co potrafię <em>najlepiej</em></h2>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:28px; margin-top:60px;">

      <% const skills = [
        {
          title: 'Web Design & Dev',
          desc: 'Tworzę strony szybkie, responsywne i zoptymalizowane pod konwersję. HTML/CSS/JS, WordPress, systemy custom.',
          level: 95,
          svg: '<svg viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2"><rect x="3" y="7" width="34" height="24" rx="2"/><line x1="3" y1="13" x2="37" y2="13"/><circle cx="8" cy="10" r="1.5" fill="#E63329"/><circle cx="13" cy="10" r="1.5" fill="#E63329"/><circle cx="18" cy="10" r="1.5" fill="#E63329"/><polyline points="10,22 15,20 10,18"/><line x1="17" y1="22" x2="23" y2="22"/></svg>'
        },
        {
          title: 'SEO lokalne',
          desc: 'Pozycjonowanie w Google Maps i organicznych wynikach. Google Business Profile, link building, optymalizacja treści.',
          level: 92,
          svg: '<svg viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2"><circle cx="18" cy="18" r="11"/><line x1="27" y1="27" x2="36" y2="36"/><line x1="18" y1="10" x2="18" y2="13"/><line x1="18" y1="23" x2="18" y2="26"/><line x1="10" y1="18" x2="13" y2="18"/><line x1="23" y1="18" x2="26" y2="18"/></svg>'
        },
        {
          title: 'Google Ads',
          desc: 'Kampanie Search, Display, Shopping i YouTube. Specjalista Google Ads z kilkuset kampaniami za sobą.',
          level: 90,
          svg: '<svg viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2"><path d="M5 30 L13 18 L20 24 L28 12 L35 18"/><polyline points="28,8 35,8 35,15"/><circle cx="13" cy="18" r="2.5" fill="#E63329" stroke="none"/><circle cx="20" cy="24" r="2.5" fill="#E63329" stroke="none"/></svg>'
        },
        {
          title: 'Grafika i branding',
          desc: 'Identyfikacja wizualna, materiały reklamowe, szablony social media. Adobe Creative Suite na co dzień.',
          level: 85,
          svg: '<svg viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2"><rect x="4" y="8" width="32" height="24" rx="2"/><circle cx="13" cy="17" r="4"/><polyline points="4,28 14,20 20,26 26,19 36,28"/></svg>'
        },
        {
          title: 'Automatyzacja',
          desc: 'Make, Zapier, customowe rozwiązania. Buduję systemy, które pracują za Ciebie 24/7.',
          level: 88,
          svg: '<svg viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2"><path d="M20 4 L36 12 L36 28 L20 36 L4 28 L4 12 Z"/><circle cx="20" cy="20" r="6"/><line x1="20" y1="14" x2="20" y2="4"/><line x1="20" y1="26" x2="20" y2="36"/></svg>'
        },
        {
          title: 'Analityka',
          desc: 'Google Analytics 4, Tag Manager, testy A/B. Decyzje oparte na danych, nie na intuicji.',
          level: 90,
          svg: '<svg viewBox="0 0 40 40" fill="none" stroke="#E63329" stroke-width="2"><rect x="4" y="4" width="32" height="32" rx="2"/><polyline points="10,28 16,20 22,24 28,14 34,18"/><line x1="4" y1="32" x2="36" y2="32"/></svg>'
        }
      ]; %>

      <% for (const skill of skills) { %>
        <div class="fade-in" style="background:var(--gray-light); padding:36px 32px;">
          <div style="width:44px; height:44px; margin-bottom:20px;"><%- skill.svg %></div>
          <h3 style="font-size:17px; font-weight:700; margin-bottom:10px; color:var(--black);"><%= skill.title %></h3>
          <p style="font-size:14px; line-height:1.6; color:var(--gray); margin-bottom:16px;"><%= skill.desc %></p>
          <div style="background:#ddd; height:3px; border-radius:2px; overflow:hidden;">
            <div style="background:var(--red); height:100%; width:<%= skill.level %>%;"></div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- WARTOŚCI -->
<section style="background:var(--black); padding:100px 60px;">
  <div class="section-inner" style="max-width:900px;">
    <div class="section-label fade-in">Wartości</div>
    <h2 class="section-title fade-in" style="color:white;">Jak <em>pracuję</em></h2>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:3px; margin-top:60px;">
      <% const values = [
        { num: '01', title: 'Szczerość przede wszystkim', desc: 'Nie obiecuję złotych gór. Jeśli coś nie zadziała, powiem o tym wprost — i zaproponuję alternatywę.' },
        { num: '02', title: 'Komunikacja bez slangu', desc: 'Tłumaczę każde działanie prostym językiem. Rozumiesz za co płacisz i dlaczego to robimy.' },
        { num: '03', title: 'Termin to termin', desc: 'Nie lubię wymówek. Jeśli ustalimy datę, dotrzymuję jej. Jeśli coś stoi na przeszkodzie, informuję z wyprzedzeniem.' },
        { num: '04', title: 'Długofalowa relacja', desc: 'Nie interesuje mnie jednorazowa transakcja. Chcę być Twoim zaufanym partnerem digital przez lata.' }
      ]; %>
      <% for (const v of values) { %>
        <div class="fade-in" style="background:#111; padding:44px 40px;">
          <div style="font-family:var(--font-display); font-size:48px; color:var(--red); margin-bottom:16px;"><%= v.num %></div>
          <h3 style="font-size:18px; font-weight:700; color:white; margin-bottom:12px;"><%= v.title %></h3>
          <p style="font-size:14px; line-height:1.7; color:rgba(255,255,255,0.5);"><%= v.desc %></p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-inner">
    <div class="section-label">Gotowy?</div>
    <h2 class="cta-title">Porozmawiajmy<br>o Twoim <em>biznesie</em></h2>
    <p class="cta-sub">Bezpłatna konsultacja, bez zobowiązań. Powiedz mi o swojej firmie — powiem Ci, co możemy razem zbudować.</p>
    <div class="cta-btns">
      <a href="/kontakt" class="btn-primary">Umów konsultację</a>
      <a href="tel:<%= settings.phone %>" class="btn-secondary">Zadzwoń teraz</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
<script src="/js/main.js"></script>
<script src="/js/extra.js"></script>
</body>
</html>
